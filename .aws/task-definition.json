{
  "family": "muud-api-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::634459150382:role/muud-production-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::634459150382:role/muud-production-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "muud-api",
      "image": "634459150382.dkr.ecr.us-west-2.amazonaws.com/muud-health-api:latest",
      "portMappings": [
        {
          "containerPort": 4000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "PORT", "value": "4000" },
        { "name": "NODE_ENV", "value": "production" },
        { "name": "AWS_REGION", "value": "us-west-2" }
      ],
      "secrets": [
        { "name": "MONGO_URI", "valueFrom": "arn:aws:secretsmanager:us-west-2:634459150382:secret:muud/prod/MONGO_URI" },
        { "name": "COGNITO_USER_POOL_ID", "valueFrom": "arn:aws:secretsmanager:us-west-2:634459150382:secret:muud/prod/COGNITO_USER_POOL_ID" },
        { "name": "COGNITO_CLIENT_ID", "valueFrom": "arn:aws:secretsmanager:us-west-2:634459150382:secret:muud/prod/COGNITO_CLIENT_ID" },
        { "name": "S3_BUCKET_NAME", "valueFrom": "arn:aws:secretsmanager:us-west-2:634459150382:secret:muud/prod/S3_BUCKET_NAME" },
        { "name": "ALLOWED_ORIGINS", "valueFrom": "arn:aws:secretsmanager:us-west-2:634459150382:secret:muud/prod/ALLOWED_ORIGINS" },
        { "name": "FIREBASE_SERVICE_ACCOUNT_JSON", "valueFrom": "arn:aws:secretsmanager:us-west-2:634459150382:secret:muud/prod/FIREBASE_SERVICE_ACCOUNT_JSON" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/muud-api",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:4000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      }
    }
  ]
}
