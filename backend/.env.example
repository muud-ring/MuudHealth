# =============================================================================
# Muud Health Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Server ---
# Port the Express server listens on
PORT=4000

# --- Database ---
# MongoDB / AWS DocumentDB connection string
# For local development: mongodb://localhost:27017/muud
# For DocumentDB: mongodb://user:pass@host:27017/muud (TLS is auto-enabled for non-localhost)
MONGO_URI=

# --- AWS General ---
# AWS region for all AWS services (Cognito, S3)
AWS_REGION=us-west-2

# AWS credentials (used for S3 and Cognito SDK calls)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- AWS Cognito (Authentication) ---
# Cognito User Pool ID (e.g., us-west-2_aBcDeFgHi)
COGNITO_USER_POOL_ID=

# Cognito App Client ID (the client used by the backend for auth operations)
COGNITO_CLIENT_ID=

# Cognito Hosted UI domain (used by frontend; documented here for reference)
# Example: https://your-prefix.auth.us-west-2.amazoncognito.com
COGNITO_DOMAIN=

# --- AWS S3 (File Storage) ---
# S3 bucket name for avatars, uploads, and media
S3_BUCKET_NAME=

# --- CORS ---
# Comma-separated list of allowed origins for CORS
# Use specific origins in production; NEVER use "*" in production
# Example: https://muudhealth.com,https://app.muudhealth.com
ALLOWED_ORIGINS=
