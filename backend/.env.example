# =============================================================================
# Muud Health Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Server ---
# Port the Express server listens on
PORT=4000

# --- Database ---
# MongoDB / AWS DocumentDB connection string
# For local development: mongodb://localhost:27017/muud
# For DocumentDB: mongodb://user:pass@host:27017/muud (TLS is auto-enabled for non-localhost)
MONGO_URI=

# --- AWS General ---
# AWS region for all AWS services (Cognito, S3)
AWS_REGION=us-west-2

# AWS credentials (used for S3 and Cognito SDK calls)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- AWS Cognito (Authentication) ---
# Cognito User Pool ID (e.g., us-west-2_aBcDeFgHi)
COGNITO_USER_POOL_ID=

# Cognito App Client ID (the client used by the backend for auth operations)
COGNITO_CLIENT_ID=

# Cognito Hosted UI domain (used by frontend; documented here for reference)
# Example: https://your-prefix.auth.us-west-2.amazoncognito.com
COGNITO_DOMAIN=

# --- AWS S3 (File Storage) ---
# S3 bucket name for avatars, uploads, and media
S3_BUCKET_NAME=

# --- CORS ---
# Comma-separated list of allowed origins for CORS
# Use specific origins in production; NEVER use "*" in production
# Example: https://muudhealth.com,https://app.muudhealth.com
ALLOWED_ORIGINS=

# --- Twilio (SMS) ---
# Twilio Account SID and Auth Token from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio phone number in E.164 format (e.g., +15551234567)
TWILIO_PHONE_NUMBER=

# --- Mailgun (Email) ---
# Mailgun API key and domain from https://app.mailgun.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Default sender address (e.g., Muud Health <noreply@mail.muudhealth.com>)
MAILGUN_FROM=

# --- Firebase (Push Notifications) ---
# Firebase service account JSON (stringified).
# Generate at: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Store the entire JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Security & Encryption ---
# AES-256 encryption key for PHI fields (64-character hex string).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Monitoring & Alerting ---
# Webhook URL for alert dispatch (Slack, PagerDuty, etc.)
ALERT_WEBHOOK_URL=

# --- Logging ---
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Enable PHI access logging (audit trail for HIPAA compliance)
LOG_PHI_ACCESS=true

# --- Feature Flags ---
# JSON object to override default feature flags.
# Example: {"ring_integration":true,"ai_insights":false}
FEATURE_FLAGS=

# --- Development ---
# Enable dev auth mode (token format: "dev-<sub>")
# NEVER enable in production
DEV_AUTH=false
